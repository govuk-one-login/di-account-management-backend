{
  "name": "di-account-home-backend",
  "version": "1.0.0",
  "description": "Account Home Backend",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "clean": "rm -rf dist node_modules logs.json",
    "test": "jest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:cov": "jest --coverage",
    "install-brewfile": "cat Brewfile; echo; echo; read -p \"Install/update Brewfile dependencies as shown above (y/N)?\" -n 1 -r; echo; if [ \"$REPLY\" == \"y\" ]; then brew bundle check || brew bundle install; fi",
    "check-gh-actions": "zizmor .",
    "check-gh-actions:fix": "zizmor . --fix",
    "sam-validate": "sam validate --region eu-west-2 --lint -t template.yaml",
    "knip": "knip",
    "knip:fix": "knip --fix --allow-remove-files",
    "install-git-hooks": "pre-commit install --install-hooks --overwrite"
  },
  "author": "GDS",
  "license": "OGL",
  "repository": {
    "type": "git",
    "url": "https://github.com/alphagov/di-account-management-backend.git"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^30.0.0",
    "@types/jest-when": "^3.5.2",
    "@types/mocha": "^10.0.10",
    "@types/ua-parser-js": "^0.7.39",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-jest": "^4.1.0",
    "axios-mock-adapter": "2.1.0",
    "babel-jest": "^30.3.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "knip": "^6.4.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2"
  },
  "dependencies": {
    "@aws-crypto/client-node": "^4.2.2",
    "@aws-lambda-powertools/logger": "^2.32.0",
    "@aws-lambda-powertools/metrics": "^2.32.0",
    "@aws-lambda-powertools/parameters": "^2.32.0",
    "@aws-sdk/client-dynamodb": "^3.1030.0",
    "@aws-sdk/client-lambda": "^3.1030.0",
    "@aws-sdk/client-secrets-manager": "^3.1030.0",
    "@aws-sdk/client-sfn": "^3.1030.0",
    "@aws-sdk/client-sqs": "^3.1030.0",
    "@aws-sdk/lib-dynamodb": "^3.1030.0",
    "@aws-sdk/util-dynamodb": "^3.985.0",
    "@types/aws-lambda": "^8.10.161",
    "axios": "^1.15.0",
    "di-account-management-rp-registry": "github:govuk-one-login/di-account-management-rp-registry#main",
    "esbuild": "0.27.3",
    "jest-when": "^4.0.1",
    "notifications-node-client": "^8.3.2",
    "ua-parser-js": "^1.0.41",
    "valibot": "^1.3.1"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,json,css,scss,md,yaml}": [
      "npx prettier --write"
    ]
  }
}
