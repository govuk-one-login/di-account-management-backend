{
  "$schema": "https://raw.githubusercontent.com/govuk-one-login/quality-gates/refs/tags/v0.1.0/schemas/schema.json",
  "services": [
    {
      "service-tag": "home",
      "quality-gates": [
        {
          "check-types": [
            "unit",
            "new feature",
            "regression",
            "code style and linting"
          ],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/lint-and-test-lambdas.yaml",
            "path": "jobs.lint_and_test",
            "name": "Lint and test lambdas"
          }
        },
        {
          "check-types": ["code quality"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/checkov.yml",
            "path": "jobs.checkov",
            "name": "Checkov"
          }
        },
        {
          "check-types": [
            "secret scanning"
          ],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/detect-secrets.yaml",
            "path": "jobs.detect-secrets",
            "name": "Detect secrets"
          }
        },        
        {
          "check-types": ["code quality", "unit test coverage", "vulnerability detection"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/sonarcloud.yaml",
            "path": "jobs.sonarcloud_home_backend",
            "name": "SonarCloud"
          }
        },
        {
          "check-types": ["integration", "regression"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/pre-merge.yaml",
            "path": "jobs.test",
            "name": "Pre Merge Check"
          }
        },
        {
          "check-types": [
            "unit",
            "new feature",
            "regression"
          ],
          "provider": "GitHub",
          "phase": "pre-upload",
          "config": {
            "file": ".github/workflows/sam-app-post-merge-actions.yaml",
            "path": "jobs.deploy"
          }
        }
      ]
    }
  ]
}
