{
  "$schema": "https://raw.githubusercontent.com/govuk-one-login/quality-gates/refs/tags/v0.1.0/schemas/schema.json",
  "services": [
    {
      "service-tag": "home",
      "quality-gates": [
        {
          "check-types": ["unit", "new feature", "regression"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/test-lambdas.yaml",
            "path": "jobs.test",
            "name": "Test lambdas"
          }
        },
        {
          "check-types": [
            "code style and linting",
            "secret scanning",
            "vulnerability detection",
            "code quality"
          ],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/check.yaml",
            "path": "jobs.check",
            "name": "Check"
          }
        },
        {
          "check-types": [
            "code quality",
            "unit test coverage",
            "vulnerability detection"
          ],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/sonarcloud.yaml",
            "path": "jobs.sonarcloud_home_backend",
            "name": "SonarCloud"
          }
        },
        {
          "check-types": ["integration", "regression"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/pre-merge.yaml",
            "path": "jobs.test",
            "name": "Pre Merge Check"
          }
        },
        {
          "check-types": ["unit", "new feature", "regression"],
          "provider": "GitHub",
          "phase": "pre-upload",
          "config": {
            "file": ".github/workflows/sam-app-post-merge-actions.yaml",
            "path": "jobs.deploy"
          }
        }
      ]
    }
  ]
}
