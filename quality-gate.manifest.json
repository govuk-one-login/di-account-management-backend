{
  "$schema": "https://raw.githubusercontent.com/govuk-one-login/quality-gates/refs/tags/v0.1.0/schemas/schema.json",
  "services": [
    {
      "service-tag": "home",
      "quality-gates": [
        {
          "check-types": [
            "code quality",
            "code style and linting",
            "secret scanning"
          ],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/lint.yaml",
            "path": "jobs.lint",
            "name": "Lint"
          }
        },
        {
          "check-types": ["vulnerability detection"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/dependency-review.yaml",
            "path": "jobs.dependency-review",
            "name": "Dependency Review"
          }
        },
        {
          "check-types": [
            "code quality",
            "unit test coverage",
            "vulnerability detection"
          ],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/sonarcloud.yaml",
            "path": "jobs.sonarcloud_home_backend",
            "name": "home_backend"
          }
        },
        {
          "check-types": ["new feature", "regression", "unit"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/local-tests-unit.yaml",
            "path": "jobs.local-tests-unit",
            "name": "Local tests (unit)"
          }
        },
        {
          "check-types": ["integration", "regression"],
          "provider": "GitHub",
          "phase": "pre-merge",
          "config": {
            "file": ".github/workflows/deployed-tests.yaml",
            "path": "jobs.deployed-tests",
            "name": "Deployed tests"
          }
        },
        {
          "check-types": ["new feature", "regression", "unit"],
          "provider": "GitHub",
          "phase": "pre-upload",
          "config": {
            "file": ".github/workflows/sam-app-post-merge-actions.yaml",
            "path": "jobs.deploy"
          }
        },
        {
          "check-types": ["integration", "regression"],
          "provider": "Stack Orchestrator",
          "phase": "build",
          "config": {
            "file": "post-deploy-tests.Dockerfile"
          }
        }
      ]
    }
  ]
}
